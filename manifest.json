{
  "manifest_version": 3,
  "name": "Focus Mode Time",
  "version": "1.1",
  "description": "ফোকাস টাইমার - হিস্টোরি এবং অ্যালার্ম কন্ট্রোল সহ।",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "alarms",
    "storage",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  }
}